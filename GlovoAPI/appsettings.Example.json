{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "USE_YOUR_CONNECTION_STRING"
  },
  "ImagesDir": "images",
  "ImageSizes": [
    50,
    100,
    200,
    400,
    800,
    1200
  ],
  "Tokens": {
    "Jwt": {
      "Key": "YOUR_JWT_KEY",
      "Issuer": "YOUR_ISSUER",
      "Audience": "MainToken",
      "LifeTime": "15" // mins
    },
    "Registration": {
      "Key": "YOUR_REGISTRATION_KEY",
      "Issuer": "YOUR_ISSUER",
      "Audience": "RegistrationToken"
    },
    "Refresh": {
      "LifeTime": "7" // days
    }
  }
}
